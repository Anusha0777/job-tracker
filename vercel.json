{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/index.py" },
    { "src": "/api/applications", "dest": "/api/index.py" },
    { "src": "/api/applications/(.*)", "dest": "/api/index.py" },
    { "src": "/api/stats", "dest": "/api/index.py" },
    { "src": "/api/ai-tip", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
